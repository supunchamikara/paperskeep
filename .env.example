# ─────────────────────────────────────────────────────────────
# Paperskeep — environment variables
# Copy to .env.local for local dev. On Vercel, add these under
# Project → Settings → Environment Variables (never commit real values).
# ─────────────────────────────────────────────────────────────

# Supabase (public — safe to expose to the browser) ── REQUIRED at runtime
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# Canonical site URL — REQUIRED in production.
# Fixes SEO canonical tags, sitemap, RSS, and Stripe success/cancel links.
NEXT_PUBLIC_SITE_URL=https://paperskeep.com

# Stripe secret key — REQUIRED at runtime for <BuyCard/> checkout.
# Use a test key (sk_test_…) for the test/non-commercial deployment.
STRIPE_SECRET_KEY=sk_test_your_key

# ── Local-only. NOT needed on Vercel. ────────────────────────
# Used solely by `npm run db:seed` (creates the admin user + imports posts).
# Keep the service-role key off any client and out of git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAIL=admin@paperskeep.com
ADMIN_PASSWORD=change-me
